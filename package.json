{
  "name": "artifact.ci",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "deploy:dev": "alchemy deploy",
    "deploy:prod": "node --env-file=.env.prod node_modules/alchemy/bin/alchemy.js deploy --stage prod",
    "destroy:dev": "alchemy destroy",
    "destroy:prod": "node --env-file=.env.prod node_modules/alchemy/bin/alchemy.js destroy --stage prod",
    "auth:generate": "mkdir -p ./tmp && BETTER_AUTH_SCHEMA_GENERATE=1 better-auth generate --config ./auth.ts --output ./tmp/better-auth-generated.sql --yes",
    "generate": "node scripts/build-action.js",
    "build-actions": "node scripts/build-action.js",
    "dev": "bash ./scripts/dev.sh",
    "dev:server": "alchemy dev",
    "tunnel": "bash ./scripts/tunnel.sh start",
    "tunnel:stop": "bash ./scripts/tunnel.sh stop",
    "tunnel:status": "bash ./scripts/tunnel.sh status",
    "prepare": "simple-git-hooks",
    "build": "pnpm --dir apps/app build && pnpm --dir apps/docs build && pnpm exec tsc --noEmit",
    "start": "bash ./scripts/dev.sh",
    "lint": "pnpm eslint .",
    "typecheck": "tsgo --noEmit",
    "e2e": "playwright test",
    "typegen": "sqlfu generate",
    "z": "tsx zignoreme/cli.ts"
  },
  "dependencies": {
    "@actions/artifact": "^2.1.9",
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.5.0",
    "@actions/http-client": "^2.2.3",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.35.3",
    "@octokit/webhooks": "^13.3.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-start": "^1.166.16",
    "@trpc/client": "11.0.0-rc.553",
    "@trpc/react-query": "11.0.0-rc.553",
    "@trpc/server": "11.0.0-rc.553",
    "alchemy": "^0.89.0",
    "astro": "^5.18.1",
    "aws4fetch": "^1.0.20",
    "badge-maker": "^4.1.0",
    "better-auth": "^1.5.5",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.447.0",
    "marked": "^17.0.1",
    "mime": "^4.0.4",
    "mime-types": "^2.1.35",
    "octokit": "^4.0.2",
    "p-all": "^5.0.0",
    "p-map": "^7.0.2",
    "p-suite": "^0.0.1",
    "posthog-js": "^1.167.0",
    "posthog-node": "^4.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "source-map-support": "^0.5.21",
    "sqlfu": "https://pkg.pr.new/mmkal/sqlfu/sqlfu@b25d208",
    "supports-color": "8.1.1",
    "tailwindcss-animate": "^1.0.7",
    "tar-stream": "^3.1.7",
    "unzipit": "^1.4.3",
    "zod": "^3.25.17",
    "zod-validation-error": "^3.4.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.29.1",
    "@playwright/test": "1.46.1",
    "@types/mime-types": "^2.1.1",
    "@types/node": "^22.7.5",
    "@types/react": "^18.0.22",
    "@types/react-dom": "^18.0.7",
    "@types/tar-stream": "3.1.3",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "eslint-plugin-mmkal": "https://pkg.pr.new/mmkal/eslint-plugin-codegen/eslint-plugin-mmkal@beece09",
    "expect-type": "^1.0.0",
    "postcss": "^8.4.47",
    "simple-git-hooks": "^2.11.1",
    "tailwindcss": "^3.4.13",
    "ts-morph": "26.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.5.4",
    "vite": "^8.0.0",
    "vitest": "2.1.1",
    "wrangler": "^4.75.0",
    "yaml": "^2.5.1"
  },
  "simple-git-hooks": {
    "pre-commit": "git diff --quiet origin bundled-action src/action || (node --run generate && git diff --quiet bundled-action || git add bundled-action)",
    "pre-push": "git diff --quiet origin bundled-action src/action || (node --run generate && git diff --quiet bundled-action)"
  }
}
