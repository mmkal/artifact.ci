{
  "name": "artifact.ci",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "auth:generate": "mkdir -p ./tmp && better-auth generate --config ./auth.ts --output ./tmp/better-auth-generated.sql --yes",
    "pgkit-link": "npx link ../pgkit/packages/pgkit",
    "pgkit": "node node_modules/pgkit/dist/cli.js",
    "build-supabase-client": "openapi-typescript --default-non-nullable=false https://supabase.github.io/storage/api.json -o src/openapi/generated/supabase-storage.ts",
    "generate": "pnpm /build-.+-action/",
    "build-badge-action": "esbuild src/action/badge.ts --bundle --platform=node --target=node20 --outfile=bundled-action/badge.min.js --minify",
    "build-upload-action": "esbuild src/action/upload.ts --bundle --platform=node --target=node20 --outfile=bundled-action/upload.min.js --minify",
    "dev": "alchemy dev",
    "prepare": "simple-git-hooks",
    "build": "pnpm --dir apps/app build && pnpm --dir apps/docs build && pnpm exec tsc --noEmit",
    "start": "alchemy dev",
    "lint": "pnpm eslint .",
    "typecheck": "tsgo --noEmit",
    "e2e": "playwright test",
    "typegen": "pgkit generate",
    "def": "pgkit migrate.definitions.updateDb",
    "z": "tsx zignoreme/cli.ts"
  },
  "dependencies": {
    "@actions/artifact": "^2.1.9",
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.5.0",
    "@actions/http-client": "^2.2.3",
    "@astrojs/cloudflare": "^13.1.2",
    "@astrojs/react": "^5.0.0",
    "@astrojs/starlight": "^0.38.1",
    "@octokit/webhooks": "^13.3.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-start": "^1.166.16",
    "@trpc/client": "11.0.0-rc.553",
    "@trpc/react-query": "11.0.0-rc.553",
    "@trpc/server": "11.0.0-rc.553",
    "@vercel/blob": "^0.23.4",
    "@vercel/functions": "^1.4.2",
    "alchemy": "^0.89.0",
    "astro": "^6.0.5",
    "badge-maker": "^4.1.0",
    "better-auth": "^1.5.5",
    "cheerio": "^1.0.0",
    "lucide-react": "^0.447.0",
    "marked": "^17.0.1",
    "mime": "^4.0.4",
    "mime-types": "^2.1.35",
    "next": "^14.2.29",
    "next-auth": "5.0.0-beta.20",
    "nextra": "^3.0.8",
    "nextra-theme-docs": "^3.0.8",
    "octokit": "^4.0.2",
    "p-all": "^5.0.0",
    "p-map": "^7.0.2",
    "p-suite": "^0.0.1",
    "pg": "^8.20.0",
    "pgkit": "^0.5.0",
    "posthog-js": "^1.167.0",
    "posthog-node": "^4.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "source-map-support": "^0.5.21",
    "supports-color": "8.1.1",
    "tailwindcss-animate": "^1.0.7",
    "tar-stream": "^3.1.7",
    "unzipit": "^1.4.3",
    "zod": "^3.25.17",
    "zod-validation-error": "^3.4.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.29.1",
    "@pgkit/admin": "0.6.1",
    "@playwright/test": "1.46.1",
    "@types/mime-types": "^2.1.1",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.0.22",
    "@types/react-dom": "^18.0.7",
    "@types/tar-stream": "3.1.3",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "eslint-plugin-mmkal": "https://pkg.pr.new/mmkal/eslint-plugin-codegen/eslint-plugin-mmkal@beece09",
    "expect-type": "^1.0.0",
    "openapi-typescript": "^7.4.1",
    "postcss": "^8.4.47",
    "simple-git-hooks": "^2.11.1",
    "tailwindcss": "^3.4.13",
    "ts-morph": "26.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.5.4",
    "vite": "^8.0.0",
    "wrangler": "^4.75.0",
    "yaml": "^2.5.1"
  },
  "simple-git-hooks": {
    "pre-commit": "git diff --quiet origin bundled-action src/action || (node --run generate && git diff --quiet bundled-action || git add bundled-action)",
    "pre-push": "git diff --quiet origin bundled-action src/action || (node --run generate && git diff --quiet bundled-action)"
  }
}
