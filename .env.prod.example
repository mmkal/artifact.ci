# Template for .env.prod — copy to `.env.prod` (gitignored) and fill in
# real values. Loaded via `pnpm deploy:prod` (node --env-file=.env.prod).
#
# Dev equivalents live in `.env`. Prod and dev are fully independent:
# different D1 database, different R2 bucket, different GitHub App,
# different better-auth secret, different alchemy state-encryption
# password. Nothing is shared.

# --- github app (production: artifact-ci — NOT the dev app) ---
GITHUB_APP_URL=https://github.com/apps/artifact-ci
GITHUB_APP_ID=1009491
GITHUB_APP_CLIENT_ID=<prod>
GITHUB_APP_CLIENT_SECRET=<prod>
GITHUB_APP_WEBHOOK_SECRET=<prod>
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
<...>
-----END RSA PRIVATE KEY-----"

# --- Better Auth ---
# baseURL priority in server-auth.ts is BETTER_AUTH_URL > PUBLIC_DEV_URL
# > AUTH_URL, so setting this pins OAuth redirects to the prod domain.
BETTER_AUTH_URL=https://artifact.ci
# Generate a fresh value so prod cookies are isolated from dev:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=<generate>

# --- R2 ---
# S3-compatible API token for signing presigned PUTs from the worker.
# Mint at https://dash.cloudflare.com → R2 → Manage R2 API Tokens →
# Object Read & Write, scoped to `artifact-ci-prod-blobs`.
R2_ACCESS_KEY_ID=<prod>
R2_SECRET_ACCESS_KEY=<prod>

# --- PostHog (same project, different key is optional) ---
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=96038
POSTHOG_PROJECT_API_KEY=<prod>

# --- alchemy ---
# Encrypts the resource state files. Use a fresh value per stage so
# dev state (stage=mmkal) and prod state (stage=prod) don't collide.
#   openssl rand -base64 32
ALCHEMY_PASSWORD=<generate>

# --- misc ---
# Only needed if you run the e2e suite against prod; leave unset otherwise.
# GH_TOKEN=<classic PAT>
